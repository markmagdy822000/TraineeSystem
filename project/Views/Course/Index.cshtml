@model List<Course>

@{
    ViewData["Title"] = "Index";
    // Layout = "_AdvLayout";
}



<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Courses</h1>
        <a asp-action="Add" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Course
        </a>
        <form asp-action="Index" asp-controller="Course" method="post" class="form-responsive">
            <input class="form-check form-control" name="searchTxt" /> 
            <input type="submit" class="btn btn-light"value="Search"/>
        </form>
    </div>

    <div class="row">
        @foreach (var course in @Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    
                    <div class="card-body">
                        <p class="card-text text-muted">@course.Name</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary">Full Degree: @course.Degree</span>
                            
                        </div>
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-between">
                        <a asp-action="GetAllTrainees" asp-route-cid="@course.Id"  class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye"></i> View
                        </a>
                        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@course.Id">Edit</a>
                        <form asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete?')" method="post" asp-route-Id="@course.Id">
                            <input type="submit" class="btn btn-danger" value="Delete" />
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

     @if (!@Model.Any()) 
     { 
         <div class="alert alert-info mt-4"> 
             <i class="bi bi-info-circle"></i> No courses found. Would you like to add one? 
         </div> 
     } 

     <div>
        <a class="btn btn-primary" asp-action="Index" asp-route-isNext="1">Next</a>
        <a class="btn btn-primary" asp-action="Index" asp-route-isNext="2">Prev</a>
    </div>
</div>

