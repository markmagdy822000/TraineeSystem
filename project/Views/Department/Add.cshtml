@model Department
@{
    ViewData["Title"] = "Add";
}

<h1>Add New Department</h1>

<form action="/Department/Add" method="post" >
    
    <div>
        <label>Department Name</label>
        <input type="text" name="Name" value="@Model?.Name" class="form form-control" />
    </div> 
    <div>
        <label>Manager Name</label>
        <input type="text" name="ManagerName" value="@Model?.ManagerName"  class="form form-control" />
    </div>
    <input type="submit" value="Create New Department" class="btn btn-success" />
</form>

<a class="btn btn-primary" asp-action="Index"> Go Back</a>