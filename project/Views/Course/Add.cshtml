@model Course_Deparmtent_ViewModel
@{
    ViewData["Title"] = "Add";
    SelectList DeptList = new SelectList(Model.Departments,"Id","Name");
}

<h1>Add New Course</h1>



<form action="/Course/SaveAdd" class="form-responsive">
    <input hidden type="text" class="form form-control" name="Id" id="@Model.Id" value="@Model.Id" />

    <div>
        <label>Name</label>
        <input type="text" class="form form-control" asp-for="Name"  />
    </div>

    <div>
        <label>Degree</label>
        <input type="number" class="form form-control" asp-for="Degree" />
    </div>

    <div>
        <label>MinDegree</label>
        <input type="number" class="form form-control" asp-for="MinDegree" />
    </div>

    <div>
        <label>Hours</label>
        <input type="number" class="form form-control" asp-for="Hours" />
    </div>

    <div>
        <label asp-for="Departments"></label>
        <select class="form form-control" asp-for="DepartmentId" asp-items="DeptList"></select>
    </div>

    <input type="submit" value="Add" class="btn btn-success" />
</form>